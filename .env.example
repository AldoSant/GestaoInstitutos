# Utilizado pelo Docker Compose. Não mantenha o valor de exemplo em nenhum ambiente.
POSTGRES_PASSWORD=troque-por-uma-senha-longa-e-exclusiva
AUTH_SECRET=gere-uma-chave-aleatoria-com-pelo-menos-32-bytes

# Utilizado por comandos executados diretamente no host.
DATABASE_URL=postgresql://instituto:troque-esta-senha@localhost:5432/instituto_folha
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT_MS=5000
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_STATEMENT_TIMEOUT_MS=30000
DATABASE_QUERY_TIMEOUT_MS=35000
DATABASE_IDLE_TRANSACTION_TIMEOUT_MS=30000
DATABASE_APPLICATION_NAME=gestao-institutos-local
WORKER_POLL_INTERVAL_MS=2000
WORKER_LEASE_TIMEOUT_MINUTES=15

# Somente para a coleta local do legado. Não versionar credenciais reais.
GIW_URL=http://ws.marvsolutions.com.br:9050/instituto/open.do?sys=GIW
GIW_USUARIO=
GIW_SENHA=
GIW_HEADLESS=true
